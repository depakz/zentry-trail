<!doctype html><html><head><meta charset="utf-8">
<title>{{ s.target }} - Bug Bounty Report</title>
<style>
body{font-family:-apple-system,Segoe UI,sans-serif;background:#0d1117;color:#c9d1d9;margin:0;padding:30px}
h1,h2{color:#58a6ff}.f{background:#161b22;border-left:4px solid;padding:15px;margin:15px 0;border-radius:6px}
.critical{border-color:#f85149}.high{border-color:#ff7b72}.medium{border-color:#d29922}.low{border-color:#3fb950}
code{background:#21262d;padding:2px 6px;border-radius:3px;font-size:13px}
table{width:100%;border-collapse:collapse}td,th{padding:8px;border-bottom:1px solid #30363d;text-align:left}
.score{float:right;background:#1f6feb;padding:3px 10px;border-radius:12px;color:white}
</style></head><body>
<h1>🎯 Bug Bounty Report — {{ s.target }}</h1>
<p>Started: {{ s.started }} • Validated findings: <b>{{ s.findings|length }}</b></p>

<h2>📊 Summary</h2>
<table>
  <tr><th>Subdomains</th><td>{{ s.subdomains|length }}</td></tr>
  <tr><th>Alive hosts</th><td>{{ s.alive_hosts|length }}</td></tr>
  <tr><th>Endpoints</th><td>{{ s.endpoints|length }}</td></tr>
</table>

<h2>🔥 Validated Findings</h2>
{% for f in s.findings %}
<div class="f {{ f.severity }}">
  <span class="score">Score {{ f.score }}</span>
  <h3>[{{ f.severity|upper }}] {{ f.title }}</h3>
  <b>Endpoint:</b> <code>{{ f.endpoint }}</code><br>
  {% if f.payload %}<b>Payload:</b> <code>{{ f.payload }}</code><br>{% endif %}
  <b>Evidence:</b> {{ f.evidence }}<br>
  {% if f.reproduction %}
    <b>Reproduction:</b><ol>{% for r in f.reproduction %}<li>{{ r }}</li>{% endfor %}</ol>
  {% endif %}
  {% if f.impact %}<b>Impact:</b> {{ f.impact }}{% endif %}
</div>
{% else %}<p>✅ No validated vulnerabilities (no false positives reported).</p>{% endfor %}
</body></html>
